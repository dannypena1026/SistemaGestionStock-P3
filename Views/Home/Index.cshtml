@{
    ViewData["Title"] = "Dashboard";
    var rolId = ViewBag.RolId as string;
    var esAdmin = rolId == "1";
}

<div class="container-fluid px-4 py-3">

    <!-- Encabezado -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0 fw-bold">Dashboard</h2>
            <small class="text-muted">
                Bienvenido, <strong>@ViewBag.NombreUsuario</strong> —
                <span class="badge @(esAdmin ? "bg-danger" : "bg-secondary")">
                    @(esAdmin ? "Administrador" : "Usuario")
                </span>
            </small>
        </div>
        <span class="text-muted small">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</span>
    </div>

    <!-- Alertas -->
    @if (ViewBag.ProductosSinStock > 0)
    {
        <div class="alert alert-danger d-flex align-items-center" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>Hay @ViewBag.ProductosSinStock producto(s) sin stock.</strong>
        </div>
    }
    @if (ViewBag.ProductosBajoStock > 0)
    {
        <div class="alert alert-warning d-flex align-items-center" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>
            <strong>Hay @ViewBag.ProductosBajoStock producto(s) con bajo inventario.</strong>
        </div>
    }

    <!-- Tarjetas KPI -->
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 bg-primary bg-opacity-10 p-3">
                        <span style="font-size:1.8rem">📦</span>
                    </div>
                    <div>
                        <div class="text-muted small">Total Productos</div>
                        <div class="fw-bold fs-3 text-primary">@ViewBag.TotalProductos</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 bg-success bg-opacity-10 p-3">
                        <span style="font-size:1.8rem">🏷️</span>
                    </div>
                    <div>
                        <div class="text-muted small">Total Categorías</div>
                        <div class="fw-bold fs-3 text-success">@ViewBag.TotalCategorias</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 bg-warning bg-opacity-10 p-3">
                        <span style="font-size:1.8rem">📉</span>
                    </div>
                    <div>
                        <div class="text-muted small">Bajo Stock</div>
                        <div class="fw-bold fs-3 text-warning">@ViewBag.ProductosBajoStock</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 bg-danger bg-opacity-10 p-3">
                        <span style="font-size:1.8rem">🚫</span>
                    </div>
                    <div>
                        <div class="text-muted small">Sin Stock</div>
                        <div class="fw-bold fs-3 text-danger">@ViewBag.ProductosSinStock</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla bajo stock + Últimos productos -->
    <div class="row g-3">

        <!-- Tabla productos con bajo stock -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom fw-semibold">
                    Productos con Stock Crítico
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Producto</th>
                                    <th>Categoría</th>
                                    <th class="text-center">Stock</th>
                                    <th class="text-center">Mínimo</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.ListaBajoStock != null)
                                {
                                    foreach (var p in ViewBag.ListaBajoStock)
                                    {
                                        <tr class="@(p.Stock == 0 ? "table-danger" : "table-warning")">
                                            <td>@p.Nombre</td>
                                            <td>@p.Categoria?.Nombre</td>
                                            <td class="text-center fw-bold">@p.Stock</td>
                                            <td class="text-center">@p.StockMinimo</td>
                                        </tr>
                                    }
                                }
                                @if (ViewBag.ListaBajoStock == null || ViewBag.ListaBajoStock.Count == 0)
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-success py-3">
                                            Todos los productos tienen stock suficiente
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Últimos productos agregados -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom fw-semibold">
                   Últimos Productos Agregados
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Producto</th>
                                    <th>Categoría</th>
                                    <th class="text-end">Precio</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.UltimosProductos != null)
                                {
                                    foreach (var p in ViewBag.UltimosProductos)
                                    {
                                        <tr>
                                            <td>@p.Nombre</td>
                                            <td>
                                                <span class="badge bg-secondary">@p.Categoria?.Nombre</span>
                                            </td>
                                            <td class="text-end fw-semibold">
                                                $@p.Precio.ToString("N2")
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>